# JobPulse environment overrides. Copy to .env and adjust.
# .env is gitignored; only .env.example is committed.

# Path to the YAML config (defaults to ./config.yaml).
JOBPULSE_CONFIG=config.yaml

# Master switch for the in-process scheduler.
#   true  → app fires scrapes 3x/day + nightly cleanup at the times in config.yaml
#   false → no automatic runs; trigger scrapes manually from the UI (dev mode)
# Overrides the `cron.enabled` value in config.yaml.
JOBPULSE_CRON_ENABLED=false
